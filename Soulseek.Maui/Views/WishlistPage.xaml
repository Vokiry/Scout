<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Soulseek.Maui.ViewModels"
             x:Class="Soulseek.Maui.Views.WishlistPage"
             x:DataType="vm:WishlistViewModel"
             Title="Wishlist"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="8" RowSpacing="8">

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry Placeholder="Artist, album, or track..."
                   Text="{Binding NewPhrase}"
                   ReturnCommand="{Binding AddItemCommand}"
                   HeightRequest="44" />
            <Button Text="Add"
                    Command="{Binding AddItemCommand}"
                    WidthRequest="64"
                    HeightRequest="44" />
        </Grid>

        <Label Text="{Binding StatusText}"
               Style="{StaticResource Caption}"
               Grid.Row="1" />

        <CollectionView Grid.Row="2"
                         ItemsSource="{Binding Items}"
                         SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Remove"
                                           BackgroundColor="{StaticResource Error}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WishlistViewModel}}, Path=RemoveItemCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border Stroke="{StaticResource Divider}"
                                StrokeThickness="1"
                                Margin="0,1"
                                Padding="12,10"
                                BackgroundColor="{StaticResource Surface}"
                                StrokeShape="RoundRectangle 6">
                            <Label Text="{Binding .}" FontSize="15" />
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="32">
                    <Label Text="Wishlist is empty"
                           Style="{StaticResource Subhead}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Add artists or albums you're looking for"
                           Style="{StaticResource Caption}"
                           HorizontalTextAlignment="Center"
                           Margin="0,8,0,0" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>

</ContentPage>
