<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Soulseek.Maui.ViewModels"
             x:Class="Soulseek.Maui.Views.DownloadsPage"
             x:DataType="vm:DownloadsViewModel"
             Title="Downloads"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*" Padding="8" RowSpacing="8">

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Label Text="{Binding StatusText}"
                   Style="{StaticResource Subhead}"
                   VerticalTextAlignment="Center" />
            <Button Text="{Binding ShowActiveOnly, Converter={StaticResource BoolToFilterText}}"
                    Command="{Binding ToggleFilterCommand}"
                    Style="{StaticResource SmallButton}" />
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:DownloadItem">
                    <Border Stroke="{StaticResource Divider}"
                            StrokeThickness="1"
                            Margin="0,2"
                            Padding="12,8"
                            BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 8">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Filename}"
                                       LineBreakMode="TailTruncation"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding StateDisplay}"
                                       TextColor="{Binding State, Converter={StaticResource DownloadStateColor}}"
                                       FontSize="12"
                                       Grid.Column="1" />
                            </Grid>
                            <ProgressBar Grid.Row="1"
                                          Progress="{Binding Percentage}"
                                          HeightRequest="6" />
                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                <Label Text="{Binding ProgressText}"
                                       Style="{StaticResource Caption}" />
                                <Label Text="{Binding SpeedText}"
                                       Style="{StaticResource Caption}"
                                       Grid.Column="1" />
                                <Label Text="{Binding Username}"
                                       Style="{StaticResource Caption}"
                                       Grid.Column="2" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="32">
                    <Label Text="No downloads"
                           Style="{StaticResource Headline}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Download files from search results or browse"
                           Style="{StaticResource Caption}"
                           HorizontalTextAlignment="Center"
                           Margin="0,8,0,0" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>

</ContentPage>
