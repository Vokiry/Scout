<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Soulseek.Maui.ViewModels"
             x:Class="Soulseek.Maui.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="20">

            <Label Text="Server" Style="{StaticResource Headline}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Placeholder="server.slsknet.org"
                       Text="{Binding ServerHost}"
                       HeightRequest="44" />
                <Entry Placeholder="2244"
                       Text="{Binding ServerPort}"
                       WidthRequest="80"
                       Keyboard="Numeric"
                       HeightRequest="44"
                       Grid.Column="1" />
            </Grid>
            <Button Text="Apply Server Settings"
                    Command="{Binding SaveServerCommand}"
                    Style="{StaticResource SecondaryButton}"
                    HeightRequest="40" />

            <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

            <Label Text="Privacy" Style="{StaticResource Headline}" />
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Save password"
                       VerticalTextAlignment="Center" />
                <Switch IsToggled="{Binding SavePassword}"
                        Grid.Column="1" />
            </Grid>

            <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

            <Label Text="Notifications" Style="{StaticResource Headline}" />
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="PM &amp; download notifications"
                       VerticalTextAlignment="Center" />
                <Switch IsToggled="{Binding NotificationsEnabled}"
                        Grid.Column="1" />
            </Grid>

            <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

            <Label Text="Downloads" Style="{StaticResource Headline}" />
            <Label Text="{Binding DownloadPath, StringFormat='Save to: {0}'}"
                   Style="{StaticResource Caption}" />

            <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

            <Label Text="About" Style="{StaticResource Headline}" />
            <Label Text="{Binding VersionInfo}" Style="{StaticResource Subhead}" />
            <Label Text="Soulseek protocol client for Android. Uses the Soulseek peer-to-peer network to search and download files."
                   Style="{StaticResource Caption}" />

            <Button Text="Reset All Settings"
                    Command="{Binding ResetSettingsCommand}"
                    Style="{StaticResource DangerButton}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
