<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Soulseek.Maui.ViewModels"
             x:Class="Soulseek.Maui.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center" Padding="32" Spacing="16">

            <Label Text="Scout"
                   FontSize="42"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource Primary}"
                   Margin="0,0,0,4" />

            <Label Text="Soulseek for Android"
                   Style="{StaticResource Subhead}"
                   HorizontalTextAlignment="Center"
                   FontSize="15"
                   Margin="0,0,0,20" />

            <Entry Placeholder="Username"
                   Text="{Binding Username}"
                   ReturnType="Next"
                   HeightRequest="48" />

            <Entry Placeholder="Password"
                   Text="{Binding Password}"
                   IsPassword="True"
                   ReturnType="Done"
                   ReturnCommand="{Binding ConnectCommand}"
                   HeightRequest="48" />

            <Grid ColumnDefinitions="*,Auto" Margin="0,-4,0,0">
                <Label Text="Save password"
                       Style="{StaticResource Caption}"
                       VerticalTextAlignment="Center" />
                <Switch IsToggled="{Binding SavePassword}"
                        Grid.Column="1" />
            </Grid>

            <Button Text="{Binding IsConnecting, Converter={StaticResource BoolToLoginText}}"
                    Command="{Binding ConnectCommand}"
                    IsEnabled="{Binding IsConnecting, Converter={StaticResource InvertBool}}"
                    HeightRequest="50" />

            <ActivityIndicator IsRunning="{Binding IsConnecting}"
                               IsVisible="{Binding IsConnecting}"
                               HeightRequest="32" />

            <Label Text="{Binding StatusText}"
                   Style="{StaticResource Caption}"
                   HorizontalTextAlignment="Center"
                   Margin="0,-8,0,0" />

            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="0,12" />

            <Label Text="Server Settings"
                   Style="{StaticResource Subhead}"
                   HorizontalTextAlignment="Center" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Placeholder="server.slsknet.org"
                       Text="{Binding ServerHost}"
                       Grid.Column="0"
                       HeightRequest="44" />
                <Entry Placeholder="2244"
                       Text="{Binding ServerPort}"
                       Grid.Column="1"
                       WidthRequest="80"
                       Keyboard="Numeric"
                       HeightRequest="44" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
