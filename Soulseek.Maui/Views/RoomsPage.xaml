<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Soulseek.Maui.ViewModels"
             x:Class="Soulseek.Maui.Views.RoomsPage"
             x:DataType="vm:RoomsViewModel"
             Title="Rooms"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="8" RowSpacing="8">

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry Placeholder="Room name..."
                   Text="{Binding JoinRoomName}"
                   ReturnCommand="{Binding JoinRoomCommand}"
                   HeightRequest="44" />
            <Button Text="Join"
                    Command="{Binding JoinRoomCommand}"
                    WidthRequest="64"
                    HeightRequest="44" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,0,0,4">
            <HorizontalStackLayout Spacing="6">
                <Label Text="{Binding CurrentRoom, StringFormat='Room: {0}'}"
                       Style="{StaticResource Subhead}"
                       VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Grid.Column="1" Spacing="6">
                <Picker ItemsSource="{Binding JoinedRooms}"
                        SelectedItem="{Binding SelectedRoom}"
                        WidthRequest="120"
                        HeightRequest="36"
                        IsVisible="{Binding JoinedRooms.Count, Converter={StaticResource IntToBool}}" />
                <Button Text="Leave"
                        Command="{Binding LeaveRoomCommand}"
                        Style="{StaticResource DangerButton}"
                        HeightRequest="32"
                        FontSize="11"
                        Padding="8,4" />
            </HorizontalStackLayout>
        </Grid>

        <CollectionView Grid.Row="2"
                         ItemsSource="{Binding Messages}"
                         SelectionMode="None"
                         ItemsUpdatingScrollMode="KeepLastItemInView">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:RoomMessageItem">
                    <VerticalStackLayout Padding="8,4">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="{Binding Username}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   FontSize="13" />
                            <Label Text="{Binding Timestamp}"
                                   Style="{StaticResource Caption}"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding Message}"
                               Margin="0,2,0,0"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="Join a room to start chatting"
                       Style="{StaticResource Caption}"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </CollectionView.EmptyView>
        </CollectionView>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,4,0,0">
            <Entry Placeholder="Type a message..."
                   Text="{Binding MessageText}"
                   ReturnCommand="{Binding SendMessageCommand}"
                   HeightRequest="44" />
            <Button Text="Send"
                    Command="{Binding SendMessageCommand}"
                    WidthRequest="64"
                    HeightRequest="44"
                    IsEnabled="{Binding CurrentRoom.Length, Converter={StaticResource IntToBool}}" />
        </Grid>

    </Grid>

</ContentPage>
