<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#1DB954</Color>
    <Color x:Key="PrimaryDark">#169C46</Color>
    <Color x:Key="PrimaryLight">#2EE76A</Color>
    <Color x:Key="Secondary">#535766</Color>
    <Color x:Key="Background">#121212</Color>
    <Color x:Key="Surface">#1E1E1E</Color>
    <Color x:Key="SurfaceLight">#282828</Color>
    <Color x:Key="SurfaceHighlight">#333333</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#B3B3B3</Color>
    <Color x:Key="TextMuted">#727272</Color>
    <Color x:Key="Error">#CF6679</Color>
    <Color x:Key="Success">#1DB954</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Divider">#333333</Color>

</ResourceDictionary>
